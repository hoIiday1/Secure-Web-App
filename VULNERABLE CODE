from flask import Flask, request, render_template_string
import sqlite3
app = Flask(__name__)
def init_db():
    conn = sqlite3.connect('students.db')
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS students
                 (id INTEGER PRIMARY KEY, name TEXT, grade TEXT, email TEXT)''')
    c.execute("DELETE FROM students")
    c.execute("INSERT INTO students VALUES (1, 'Alice Johnson', 'A', 'alice@school.edu')")
    c.execute("INSERT INTO students VALUES (2, 'Bob Smith', 'B', 'bob@school.edu')")
    c.execute("INSERT INTO students VALUES (3, 'Charlie Brown', 'A', 'charlie@school.edu')")
    conn.commit()
    conn.close()
@app.route('/')
def home():
    return render_template_string('''
        <h1>Student Portal - Vulnerable Version</h1>
        <form method="POST" action="/search">
            <input type="text" name="search" placeholder="Search student name">
            <button type="submit">Search</button>
        </form>
    ''')
@app.route('/search', methods=['POST'])
def search():
    search_term = request.form['search']
    conn = sqlite3.connect('students.db')
    c = conn.cursor()
    query = f"SELECT * FROM students WHERE name LIKE '%{search_term}%'"
    c.execute(query)
    results = c.fetchall()
    conn.close()
    output = f"<h2>Results for: {search_term}</h2><ul>"
    for student in results:
        output += f"<li>{student[1]} - Grade: {student[2]} - Email: {student[3]}</li>"
    output += "</ul><br><a href='/'>Back</a>"
    return output
if __name__ == '__main__':
